# ──────────────────────────────────────────────────────────────────
# PlannerPulse — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.
# ──────────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────────

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@localhost/planner_pulse

# OpenAI API key for GPT-4o summarisation and draft generation
OPENAI_API_KEY=sk-...

# Admin login credentials (at least one of the password options is required)
ADMIN_EMAIL=admin@plannerpulse.com

# Option A (recommended): store a bcrypt hash
#   Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Option B (development only): plain-text password — leave blank in production
ADMIN_PASSWORD=

# ── Recommended ────────────────────────────────────────────────────

# Flask session secret key — generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Display name shown in the editorial dashboard
ADMIN_NAME=Editor

# ── Optional ───────────────────────────────────────────────────────

# NewsData.io API key for additional news sources (free tier: 200 credits/day)
# Sign up at https://newsdata.io
NEWSDATA_API_KEY=

# Flask server configuration (defaults shown)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Set to 'true' only for local development — NEVER in production
FLASK_DEBUG=False
