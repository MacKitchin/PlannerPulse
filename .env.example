# PlannerPulse Newsletter System - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# REQUIRED: OpenAI API Configuration
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# REQUIRED: Database Configuration
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://planner:password@localhost:5432/plannerpulse
DATABASE_URL=postgresql://user:password@localhost:5432/plannerpulse

# ============================================================================
# OPTIONAL: Flask Application Configuration
# ============================================================================
# Secret key for session management (auto-generated if not set)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Flask server host (default: 127.0.0.1 for localhost only)
# Use 0.0.0.0 to accept connections from any IP (only in trusted environments)
FLASK_HOST=127.0.0.1

# Flask server port (default: 5000)
FLASK_PORT=5000

# Flask debug mode (default: False)
# NEVER set to True in production - exposes sensitive debugging information
FLASK_DEBUG=False

# ============================================================================
# OPTIONAL: Application Features
# ============================================================================
# Enable request logging for debugging (default: False)
ENABLE_REQUEST_LOGGING=False

# Maximum OpenAI API calls per run (cost control, default: 100)
MAX_OPENAI_CALLS_PER_RUN=100

# Cache duration for dashboard stats in seconds (default: 60)
STATS_CACHE_DURATION=60

# ============================================================================
# OPTIONAL: RSS Feed Configuration
# ============================================================================
# RSS fetch timeout in seconds (default: 10)
RSS_FETCH_TIMEOUT=10

# Maximum articles per RSS feed (default: 5)
MAX_ARTICLES_PER_FEED=5

# ============================================================================
# OPTIONAL: Security Settings
# ============================================================================
# Enable CORS (Cross-Origin Resource Sharing) - use only if needed
ENABLE_CORS=False

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Production Deployment Notes
# ============================================================================
# 1. NEVER use debug mode in production (FLASK_DEBUG=False)
# 2. Always use strong SECRET_KEY (generate with secrets.token_hex(32))
# 3. Use environment variables injected by your process manager/container
# 4. Do not store .env in version control or Docker images
# 5. Rotate API keys regularly
# 6. Use HTTPS in production with reverse proxy (nginx/caddy)
# 7. Monitor OpenAI API usage and costs
# 8. Set up database backups
# 9. Configure proper firewall rules
# 10. Use connection pooling for database (already configured)
